{
  "images": {
    "rhel9": {
      "display_name": "Red Hat Enterprise Linux 9",
      "os_type": "linux",
      "workdir": "images/rhel9",
      "vars_file": "images/rhel9/rhel9.auto.pkrvars.hcl",
      "override_dir": "images/rhel9/overrides",
      "template_files": [
        "../common/packer/variables.pkr.hcl",
        "rhel9.variables.pkr.hcl",
        "rhel9.pkr.hcl",
        "../common/packer/locals.pkr.hcl"
      ],
      "builders": {
        "aws": "source.amazon-ebs.rhel9_aws",
        "azure": "source.azure-arm.rhel9_azure",
        "gcp": "source.googlecompute.rhel9_gcp"
      },
      "cis_role": "ansible-lockdown.rhel9_cis"
    },
    "win2022": {
      "display_name": "Windows Server 2022",
      "os_type": "windows",
      "workdir": "images/win2022",
      "vars_file": "images/win2022/win2022.auto.pkrvars.hcl",
      "override_dir": "images/win2022/overrides",
      "template_files": [
        "../common/packer/variables.pkr.hcl",
        "win2022.variables.pkr.hcl",
        "win2022.pkr.hcl",
        "../common/packer/locals.pkr.hcl"
      ],
      "builders": {
        "aws": "source.amazon-ebs.win2022_aws",
        "azure": "source.azure-arm.win2022_azure",
        "gcp": "source.googlecompute.win2022_gcp"
      },
      "cis_role": "ansible-lockdown.windows_2022_cis"
    }
  }
}
